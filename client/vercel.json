{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "petalsandwords.com"
        }
      ],
      "destination": "https://www.petalsandwords.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "PH"
        }
      ],
      "destination": "/api/blocked"
    },
    {
      "source": "/create",
      "destination": "/index.html"
    },
    {
      "source": "/payment",
      "destination": "/index.html"
    },
    {
      "source": "/view/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/virtual-bouquet-maker",
      "destination": "/index.html"
    },
    {
      "source": "/digital-bouquet-maker",
      "destination": "/index.html"
    },
    {
      "source": "/online-bouquet-maker",
      "destination": "/index.html"
    }
  ]
}
