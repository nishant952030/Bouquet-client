{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "petalsandwords.com"
        }
      ],
      "destination": "https://www.petalsandwords.com/$1",
      "permanent": true
    }
  ],
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/shagun/:action", "destination": "/api/shagun/router.js?action=:action" },
    { "source": "/api/stripe/:action", "destination": "/api/stripe/router.js?action=:action" },
    { "source": "/api/razorpay/:action", "destination": "/api/razorpay/router.js?action=:action" },
    { "source": "/((?!api/|@|.*\\..*).*)", "destination": "/index.html" }
  ]
}
